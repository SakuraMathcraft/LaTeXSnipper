{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LaTeXSnipper Tauri Client",
  "version": "0.1.0",
  "identifier": "com.latexsnipper.tauri.client",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LaTeXSnipper Tauri Client",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "useLocalToolsDir": true,
    "resources": {
      "../../../contracts/daemon_rpc_contract.v1.json": "contracts/daemon_rpc_contract.v1.json",
      "../../../contracts/events.v1.json": "contracts/events.v1.json",
      "../../../src/backend": "backend",
      "../../../src/core": "core",
      "../../../src/deps_bootstrap.py": "deps_bootstrap.py",
      "../../../Python311": "Python311"
    },
    "icon": [
      "icons/icon.ico"
    ]
  }
}
