#!/bin/bash

set -euo pipefail

payload="/Library/Application Support/LaTeXSnipper/OfficeAddinPayload"
console_user="$(stat -f '%Su' /dev/console)"
if [[ -z "$console_user" || "$console_user" == "root" || "$console_user" == "loginwindow" ]]; then
    echo "No logged-in user is available for Office add-in registration." >&2
    exit 1
fi

home_dir="$(dscl . -read "/Users/$console_user" NFSHomeDirectory | awk '{print $2}')"
target="$home_dir/Library/Application Support/LaTeXSnipper/OfficeAddin"
tls="$target/tls"
mkdir -p "$target" "$tls"
rm -rf "$target/site"
cp -R "$payload/site" "$target/site"

openssl_config="$tls/localhost.conf"
cat > "$openssl_config" <<'EOF'
[req]
distinguished_name = subject
x509_extensions = extensions
prompt = no
[subject]
CN = localhost
[extensions]
subjectAltName = DNS:localhost
keyUsage = digitalSignature,keyEncipherment
extendedKeyUsage = serverAuth
EOF
openssl req -x509 -nodes -newkey rsa:2048 -days 3650 \
    -keyout "$tls/server.key" \
    -out "$tls/server.crt" \
    -config "$openssl_config"
rm -f "$openssl_config"
chown -R "$console_user":staff "$target"
chmod 600 "$tls/server.key"

sudo -u "$console_user" security add-trusted-cert -d -r trustRoot \
    -k "$home_dir/Library/Keychains/login.keychain-db" "$tls/server.crt"

for host_dir in "com.microsoft.Word" "com.microsoft.Powerpoint"; do
    wef_dir="$home_dir/Library/Containers/$host_dir/Data/Documents/wef"
    mkdir -p "$wef_dir"
    cp "$payload/manifests"/*.xml "$wef_dir/"
    chown -R "$console_user":staff "$wef_dir"
done

rm -rf "$payload"
echo "LaTeXSnipper Office local runtime installed for $console_user."
echo "Restart LaTeXSnipper with the Office feature enabled, then restart Word and PowerPoint."
echo "Open LaTeXSnipper from Home > Add-ins if it is not already shown."
echo "For managed production deployment, use the release manifests through Microsoft 365 Integrated apps."
