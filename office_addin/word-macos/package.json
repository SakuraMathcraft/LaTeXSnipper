{
  "name": "@latexsnipper/word-macos-addin",
  "version": "0.1.0-dev.0",
  "private": true,
  "type": "module",
  "description": "Private development task pane for LaTeXSnipper on Word for macOS.",
  "scripts": {
    "dev": "node scripts/start-dev-server.mjs",
    "build:dev": "vite build --mode development && node scripts/check-dev-bundle.mjs",
    "cert:install": "office-addin-dev-certs install",
    "cert:uninstall": "office-addin-dev-certs uninstall",
    "manifest:validate": "office-addin-manifest validate manifest/word-dev.xml",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/office-js": "1.0.599",
    "jsdom": "29.1.1",
    "office-addin-dev-certs": "2.0.10",
    "office-addin-manifest": "2.1.6",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
