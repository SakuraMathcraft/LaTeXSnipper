                    <bt:Image size="64" resid="Ico.Help.64"/>
                    <bt:Image size="80" resid="Ico.Help.80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>helpCommand</FunctionName>
                  </Action>
                </Control>
